APP_NAME=XPERT
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# IMPORTANT: Set APP_DEBUG=false in production to prevent stack trace leaks
APP_URL=http://xpert.test

FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,localhost:5174,xpert.test,127.0.0.1,127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database — SQLite for local, PostgreSQL (Supabase) for production
DB_CONNECTION=sqlite
# For production (Supabase PostgreSQL), set:
# DB_CONNECTION=pgsql
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
# IMPORTANT: Set SESSION_ENCRYPT=true in production
SESSION_PATH=/
SESSION_DOMAIN=localhost
# For production (cross-domain Sanctum SPA auth):
# SESSION_DOMAIN=.your-render-domain.onrender.com
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=none

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@xpert.app"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# AI Service Configuration
HUGGINGFACE_API_KEY=

# External Integrations
DISCORD_WEBHOOK_URL=
RESEND_API_KEY=

GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.0-flash-exp
