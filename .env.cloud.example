# ☁️ Xpert - Laravel Cloud Environment Template
# Use this for deploying to Laravel Cloud, Render, or other modern cloud providers.

APP_NAME="Xpert AI"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-api-domain.laravel.cloud

# 🔗 Cross-Origin Configuration
# Supports comma-separated origins for multi-environment deployments.
FRONTEND_URL=https://your-app-domain.vercel.app,https://your-cloud-domain.laravel.cloud
ADMIN_URL=https://your-admin-domain.vercel.app
SANCTUM_STATEFUL_DOMAINS=your-app-domain.vercel.app,your-cloud-domain.laravel.cloud,your-api-domain.laravel.cloud

# 🍪 Session Configuration
# Ensure SESSION_DOMAIN starts with a dot if you want to share cookies across subdomains.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=.your-root-domain.com
SESSION_SECURE_COOKIE=true

# 🐘 PostgreSQL Configuration
DB_CONNECTION=pgsql
DB_HOST=your-cloud-db-host.com
DB_PORT=5432
DB_DATABASE=xpert_db
DB_USERNAME=root
DB_PASSWORD=

# 📧 Mail Configuration (Mailtrap for Staging/Testing)
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# 🧠 AI Service Keys
HUGGINGFACE_API_KEY=
GEMINI_API_KEY=

# 📂 Filesystem (S3 Recommended for Cloud)
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
