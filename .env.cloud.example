# =============================================================================
# XPERT — Laravel Cloud Environment Template
# =============================================================================
# Copy this to .env on Laravel Cloud or set these as environment variables
# in the Laravel Cloud dashboard.
#
# Domain: https://xpert-main-ev1z3t.free.laravel.cloud
# =============================================================================

APP_NAME=Xpert
APP_ENV=production
APP_KEY=  # auto-generated by php artisan key:generate
APP_DEBUG=false
APP_URL=https://xpert-main-ev1z3t.free.laravel.cloud

# -----------------------------------------------------------------------------
# Frontend URLs
# -----------------------------------------------------------------------------
# For fullstack (same-origin on Laravel Cloud):
FRONTEND_URL=https://xpert-main-ev1z3t.free.laravel.cloud
ADMIN_URL=https://xpert-main-ev1z3t.free.laravel.cloud

# If also running separate Render/Vercel frontends, comma-separate:
# FRONTEND_URL=https://xpert-main-ev1z3t.free.laravel.cloud,https://xpert-app.vercel.app
# ADMIN_URL=https://xpert-main-ev1z3t.free.laravel.cloud,https://xpert-admin.vercel.app

# -----------------------------------------------------------------------------
# Sanctum / Auth
# -----------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=xpert-main-ev1z3t.free.laravel.cloud
SESSION_DOMAIN=.free.laravel.cloud
SESSION_DRIVER=database
SESSION_LIFETIME=120

# -----------------------------------------------------------------------------
# Database (Laravel Cloud provides PostgreSQL/MySQL)
# -----------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=xpert
DB_USERNAME=xpert
DB_PASSWORD=

# Or use SQLite on a volume:
# DB_CONNECTION=sqlite
# DB_DATABASE=/volumes/database/database.sqlite

# -----------------------------------------------------------------------------
# AI Services
# -----------------------------------------------------------------------------
HUGGINGFACE_API_KEY=
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# -----------------------------------------------------------------------------
# Mail (optional)
# -----------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@xpert.app
MAIL_FROM_NAME=Xpert

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=local
# For S3-compatible storage:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=

# -----------------------------------------------------------------------------
# Cache & Queue
# -----------------------------------------------------------------------------
CACHE_STORE=database
QUEUE_CONNECTION=database

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=warning

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
BCRYPT_ROUNDS=12
