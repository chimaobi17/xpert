{
  "buildCommand": "cd xpert-app && npm install && npm run build",
  "outputDirectory": "xpert-app/dist",
  "framework": null,
  "installCommand": "echo 'skipping root install'",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
